{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "skvn-marine/product-collection",
  "version": "1.3.5",
  "title": "SKVN Product Collection",
  "category": "skvn-marine",
  "icon": "products",
  "description": "Dynamic SKVN product grid or carousel collection.",
  "textdomain": "skvn-marine-blocks",
  "attributes": {
    "layout": {
      "type": "string",
      "default": "grid"
    },
    "heading": {
      "type": "string",
      "default": "Featured products"
    },
    "intro": {
      "type": "string",
      "default": ""
    },
    "accessibleLabel": {
      "type": "string",
      "default": ""
    },
    "categories": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "relation": {
      "type": "string",
      "default": "OR"
    },
    "orderMode": {
      "type": "string",
      "default": "newest"
    },
    "itemsToShow": {
      "type": "number",
      "default": 3
    },
    "responsivePreset": {
      "type": "string",
      "default": "3-2-1"
    },
    "showImage": {
      "type": "boolean",
      "default": true
    },
    "imageRatio": {
      "type": "string",
      "default": "4:3"
    },
    "equalHeight": {
      "type": "boolean",
      "default": true
    },
    "badgeBehavior": {
      "type": "string",
      "default": "display"
    },
    "showPrice": {
      "type": "boolean",
      "default": true
    },
    "showSku": {
      "type": "boolean",
      "default": false
    },
    "showStock": {
      "type": "boolean",
      "default": false
    },
    "showProductCategories": {
      "type": "boolean",
      "default": true
    },
    "showProductTags": {
      "type": "boolean",
      "default": false
    },
    "productActionMode": {
      "type": "string",
      "default": "quote"
    },
    "customActionUrl": {
      "type": "string",
      "default": ""
    },
    "appendQuoteContext": {
      "type": "boolean",
      "default": true
    },
    "showArrows": {
      "type": "boolean",
      "default": true
    },
    "showPagination": {
      "type": "boolean",
      "default": true
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "autoplayDelay": {
      "type": "number",
      "default": 5000
    }
  },
  "supports": {
    "html": false
  }
}
