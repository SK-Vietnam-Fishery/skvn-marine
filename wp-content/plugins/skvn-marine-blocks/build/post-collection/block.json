{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "skvn-marine/post-collection",
  "version": "1.3.7",
  "title": "SKVN Post Collection",
  "category": "skvn-marine",
  "icon": "welcome-write-blog",
  "description": "Dynamic SKVN post grid or carousel collection.",
  "textdomain": "skvn-marine-blocks",
  "attributes": {
    "layout": {
      "type": "string",
      "default": "grid"
    },
    "eyebrow": {
      "type": "string",
      "default": ""
    },
    "heading": {
      "type": "string",
      "default": "Latest articles"
    },
    "showHeading": {
      "type": "boolean",
      "default": true
    },
    "intro": {
      "type": "string",
      "default": ""
    },
    "accessibleLabel": {
      "type": "string",
      "default": ""
    },
    "categories": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "relation": {
      "type": "string",
      "default": "OR"
    },
    "orderMode": {
      "type": "string",
      "default": "newest"
    },
    "itemsToShow": {
      "type": "number",
      "default": 3
    },
    "responsivePreset": {
      "type": "string",
      "default": "3-2-1"
    },
    "showImage": {
      "type": "boolean",
      "default": true
    },
    "imageRatio": {
      "type": "string",
      "default": "16:9"
    },
    "cardStyle": {
      "type": "string",
      "default": "default"
    },
    "equalHeight": {
      "type": "boolean",
      "default": true
    },
    "badgeBehavior": {
      "type": "string",
      "default": "display"
    },
    "showDate": {
      "type": "boolean",
      "default": true
    },
    "showAuthor": {
      "type": "boolean",
      "default": true
    },
    "showPostCategories": {
      "type": "boolean",
      "default": true
    },
    "showPostTags": {
      "type": "boolean",
      "default": false
    },
    "showExcerpt": {
      "type": "boolean",
      "default": true
    },
    "postActionMode": {
      "type": "string",
      "default": "read"
    },
    "customActionUrl": {
      "type": "string",
      "default": ""
    },
    "showArrows": {
      "type": "boolean",
      "default": true
    },
    "showPagination": {
      "type": "boolean",
      "default": true
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "autoplayDelay": {
      "type": "number",
      "default": 5000
    },
    "archiveUrl": {
      "type": "string",
      "default": ""
    },
    "archiveLabel": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false
  }
}